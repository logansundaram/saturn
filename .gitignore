# Environment
.env
*.env

# Logs
logs/
*.log

# Vector DBs / embeddings
chroma/
vectordb/
# derived RAG store cache (vectors.json/index.json/summaries.json) — rebuilt by sync()
# (comment on its own line: git treats a trailing inline comment as part of the pattern)
database/cache/

# Runtime SQLite store (checkpoints + trace runs/events/llm_calls) — churns every turn, recreated
# on first run; tracking it produced constant binary diffs in git status. Sidecars appear in WAL mode.
database/db.sqlite
database/db.sqlite-wal
database/db.sqlite-shm

# First-run setup sentinel — runtime state written on first launch; not source.
database/.setup_done

# Autosaved session (the /resume slot) - rewritten every turn; runtime state, not source.
database/sessions/_autosave.json

# Model cache
models/
ollama/

# Build
dist/
build/

# Python bytecode cache (never track — caused binary merge conflicts pre-consolidation)
__pycache__/
*.pyc

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

.vscode

CLAUDE.md

USER.md

CONSOLIDATION.md

# Claude/dev-only working docs — not shipped to installers (CLAUDE.md is the architecture
# reference; these are the build log, refactor plan, and original vision/roadmap).
NOTES.md
RESTRUCTURE.md
SATURDAY_MVP_PLAN.md

# Generated dev artifacts: benchmark result dumps (benchmarks/*.json) and Mermaid/PNG graph
# exports (graphs/). diag.log is already covered by *.log above; this catches the rest.
logging/

# Synthetic RAG test corpus, dogfooding workspace files, durable memory, and the derived
# .manifest.md summaries. All runtime/test data — these dirs are recreated empty on first run
# (iter_documents/files.py mkdir), so users start with a clean corpus and workspace.
database/documents/
database/workspace/
database/memory/