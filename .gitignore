# Environment
.env
*.env

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/

# Logs
logs/
*.log

# SQLite runtime DB (checkpoints + trace) and its WAL sidecars — runtime state, not source
database/db.sqlite
*.sqlite-shm
*.sqlite-wal

# Vector DBs / embeddings
chroma/
vectordb/
# Derived RAG store cache (vectors.json/index.json/summaries.json) — rebuilt by sync().
# (gitignore has no inline comments — the rule must be on its own line.)
database/cache/

# Agent runtime scratch — files the file tools / run_python generate per run, not source.
# Keep the directory (.gitkeep) but ignore its contents.
database/workspace/*
!database/workspace/.gitkeep

# Saved conversations (/save) — runtime state, not source.
database/sessions/

# Graded eval reports — generated by benchmark.py each run.
logging/benchmarks/*.json

# Dev scratchpads — kept locally, not shipped.
notes.txt
progress.txt
MEMORIES.md

# Model cache
models/
ollama/

# Build
dist/
build/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

.vscode

CLAUDE.md

USER.md