{
  "schema_name": "saturday_ai_dashboard_event",
  "schema_version": "0.3",
  "required_fields": [
    "event_id",
    "trace_id",
    "node_name",
    "event_type",
    "duration_ms"
  ],
  "event_types": [
    "node_start",
    "node_end",
    "tool_call",
    "retrieval",
    "warning",
    "error",
    "user_interrupt",
    "final_answer"
  ],
  "colors": {
    "retrieval": "teal",
    "error": "red",
    "user_interrupt": "amber"
  },
  "collapse_rule": "collapse repeated retrieval events after the fourth event from the same node"
}